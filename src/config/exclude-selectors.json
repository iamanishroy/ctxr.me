{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "CSS selectors for non-content elements to strip during HTML cleaning. Used by MainContentHandler in html-rewriter.ts.",
  "selectors": {
    "tags": [
      "header", "footer", "nav", "aside",
      "style", "script", "noscript",
      "iframe", "svg"
    ],

    "aria": [
      "[role=\"navigation\"]",
      "[role=\"banner\"]",
      "[role=\"contentinfo\"]",
      "[role=\"complementary\"]",
      "[role=\"search\"]",
      "[role=\"dialog\"]",
      "[role=\"alert\"]",
      "[role=\"note\"]",
      "[aria-hidden=\"true\"]",
      "[hidden]"
    ],

    "navigation": [
      ".header", ".navbar", "#header", "#navbar",
      ".navigation", "#nav",
      ".menu", "#menu",
      ".breadcrumbs", "#breadcrumbs",
      ".visually-hidden"
    ],

    "footers": [
      ".footer", "#footer",
      ".footer-links", ".footer-nav", ".site-footer"
    ],

    "sidebars": [
      ".sidebar", "#sidebar", ".side-bar"
    ],

    "popups": [
      ".modal", ".popup", ".overlay",
      ".dialog", ".drawer", ".banner", ".toast"
    ],

    "ads": [
      ".ad", ".ads", ".advertisement", ".advertising",
      ".sponsor", ".promotion", ".promo", ".advert", "#ad"
    ],

    "social": [
      ".social", ".social-media", ".social-links", "#social",
      ".share", "#share", ".sharing"
    ],

    "comments": [
      ".comments", ".comment-section"
    ],

    "cookies": [
      ".cookie", ".cookie-banner", ".consent"
    ],

    "search": [
      ".search", "#search", "#search-form"
    ],

    "widgets": [
      ".widget", "#widget",
      ".theme-switcher", ".lang-selector",
      ".skip-link", ".skip-to-content"
    ],

    "pagination": [
      ".pagination", ".pager", ".toolbar"
    ],

    "toc": [
      ".toc", ".table-of-contents", "#toc",
      ".on-this-page", "#on-this-page",
      ".docs-toolbar", ".docs-edit-link"
    ],

    "feedback": [
      ".feedback", ".was-this-helpful"
    ],

    "back_to_top": [
      ".back-to-top", "#back-to-top",
      ".scroll-to-top", ".return-to-top"
    ],

    "newsletter": [
      ".newsletter", ".announcement"
    ],

    "references": [
      ".reflist", ".references", ".reference",
      ".mw-references-wrap", ".citation",
      ".cite-backlink", ".noprint"
    ]
  }
}
